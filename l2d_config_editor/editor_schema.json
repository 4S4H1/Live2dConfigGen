          "default": 1,
          "show_in_modes": [
            "advanced"
          ]
        },
        {
          "key": "ignore_action",
          "label": "非待机状态不可拖动",
          "editor": "bool",
          "default": 1,
          "show_in_modes": [
            "advanced"
          ]
        },
        {
          "key": "range_abs",
          "label": "使用绝对值",
          "editor": "bool",
          "default": 1,
          "show_in_modes": [
            "advanced"
          ]
        },
        {
          "key": "drag_direct",
          "label": "方向响应",
          "editor": "combo",
          "default": 0,
          "show_in_modes": [
            "advanced"
          ],
          "options": [
            {
              "label": "0 不适用",
              "value": 0
            },
            {
              "label": "1 正向",
              "value": 1
            },
            {
              "label": "2 负向",
              "value": 2
            }
          ]
        },
        {
          "key": "react_pos_x",
          "label": "眼神跟随X",
          "editor": "nullable_int",
          "default": null,
          "show_in_modes": [
            "advanced"
          ]
        },
        {
          "key": "react_pos_y",
          "label": "眼神跟随Y",
          "editor": "nullable_int",
          "default": null,
          "show_in_modes": [
            "advanced"
          ]
        },
        {
          "key": "offset_circle",
          "label": "圆形偏移",
          "editor": "text",
          "default": "",
          "show_in_modes": [
            "advanced"
          ]
        },
        {
          "key": "offset_x",
          "label": "左右移动影响拖拽",
          "editor": "int",
          "default": 0,
          "show_in_modes": [
            "advanced"
          ]
        },
        {
          "key": "offset_y",
          "label": "上下移动影响拖拽",
          "editor": "int",
          "default": 0,
          "show_in_modes": [
            "advanced"
          ]
        },
        {
          "key": "smooth",
          "label": "开始拖拽响应系数",
          "editor": "int",
          "default": 100,
          "show_in_modes": [
            "advanced"
          ]
        },
        {
          "key": "revert_smooth",
          "label": "回弹拖拽响应系数",
