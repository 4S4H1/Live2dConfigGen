    "Initial": {
      "title": "初始节点",
      "category": "meta",
      "copyable": false,
      "quick_create": false,
      "resizable": false,
      "header_color": "#4f7c6a",
      "body_color": "#2b4139",
      "accent_color": "#6fc49e",
      "fields": [
        {
          "key": "tips",
          "label": "备注",
          "editor": "text",
          "default": "",
          "placeholder": "（非必填）",
          "show_in_modes": [
            "simple",
            "advanced"
          ]
        },
        {
          "key": "version",
          "label": "版本",
          "editor": "date",
          "default": "2099-09-09",
          "show_in_modes": [
            "simple",
            "advanced"
          ]
        },
        {
          "key": "CharName",
          "label": "角色名",
          "editor": "text",
          "default": "",
