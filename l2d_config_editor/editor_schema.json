{
  "required_meta_fields": [
    "author",
    "ship_skin_id",
    "memo"
  ],
  "required_meta_labels": {
    "author": "作者",
    "ship_skin_id": "角色ID",
    "memo": "角色资源名"
  },
  "ignore_lists": {
    "default": [
      "main_1",
      "main_2",
      "main_3",
      "main_4",
      "mission",
      "mission_complete",
      "complete",
      "login",
      "home",
      "mail",
      "touch_body",
      "touch_head"
    ],
    "hard": [
      "main_1",
      "main_2",
      "main_3",
      "mission",
      "mission_complete",
      "complete",
      "login",
      "home",
      "mail",
      "touch_body",
      "touch_head"
    ]
  },
  "templates": {
    "animated_action": "{type = 2 ,action = '{action_name}'}",
    "animated_active": "{enable = {},ignore = {{{ignore_values}}},idle = {target_idle}}",
    "hard_cut_action": "{type = 2 ,action = 'idle',target = 1}",
    "hard_cut_active": "{enable = {},ignore = {{{ignore_values}}},idle = {target_idle},idle_focus = 1}"
  },
  "csv_columns": [
    "id",
    "desc",
    "memo",
    "ship_skin_id",
    "draw_able_name",
    "parameter",
    "mode",
    "start_value",
    "range",
    "parts_data",
    "ignore_react",
    "react_condition",
    "ignore_action",
    "range_abs",
    "drag_direct",
    "react_pos_x",
    "react_pos_y",
    "offset_circle",
    "offset_x",
    "offset_y",
    "smooth",
    "revert_smooth",
    "revert",
    "save_parameter",
    "revert_action_index",
    "revert_idle_index",
    "gyro",
    "gyro_x",
    "gyro_y",
    "gyro_z",
    "limit_time",
    "listener_data",
    "action_trigger",
    "action_trigger_active",
    "shop_action",
    "relation_parameter"
  ],
  "csv_mapping": [
    { "column": "id", "kind": "node", "field": "id", "default": "" },
    { "column": "desc", "kind": "meta_fallback", "fields": ["memo", "CharName"], "default": "" },
    { "column": "memo", "kind": "meta", "field": "memo", "default": "" },
    { "column": "ship_skin_id", "kind": "meta", "field": "ship_skin_id", "default": 0 },
    { "column": "draw_able_name", "kind": "node", "field": "draw_able_name", "default": "" },
    { "column": "parameter", "kind": "node", "field": "parameter", "default": "" },
    { "column": "mode", "kind": "node", "field": "mode", "default": 1 },
    { "column": "start_value", "kind": "node", "field": "start_value", "default": 0 },
    { "column": "range", "kind": "node", "field": "range", "default": "" },
    { "column": "parts_data", "kind": "node", "field": "parts_data", "default": "" },
    { "column": "ignore_react", "kind": "node", "field": "ignore_react", "default": 1 },
    { "column": "react_condition", "kind": "meta", "field": "react_condition", "default": 0 },
    { "column": "ignore_action", "kind": "node", "field": "ignore_action", "default": 1 },
    { "column": "range_abs", "kind": "node", "field": "range_abs", "default": 1 },
    { "column": "drag_direct", "kind": "node", "field": "drag_direct", "default": 0 },
    { "column": "react_pos_x", "kind": "node", "field": "react_pos_x", "default": "" },
    { "column": "react_pos_y", "kind": "node", "field": "react_pos_y", "default": "" },
    { "column": "offset_circle", "kind": "const", "default": "" },
    { "column": "offset_x", "kind": "node", "field": "offset_x", "default": 0 },
    { "column": "offset_y", "kind": "node", "field": "offset_y", "default": 0 },
    { "column": "smooth", "kind": "node", "field": "smooth", "default": 100 },
    { "column": "revert_smooth", "kind": "node", "field": "revert_smooth", "default": 100 },
    { "column": "revert", "kind": "node", "field": "revert", "default": -1 },
    { "column": "save_parameter", "kind": "const", "default": "" },
    { "column": "revert_action_index", "kind": "const", "default": "" },
    { "column": "revert_idle_index", "kind": "const", "default": "" },
    { "column": "gyro", "kind": "node", "field": "gyro", "default": 0 },
    { "column": "gyro_x", "kind": "node", "field": "gyro_x", "default": 0 },
    { "column": "gyro_y", "kind": "node", "field": "gyro_y", "default": 0 },
    { "column": "gyro_z", "kind": "node", "field": "gyro_z", "default": 0 },
    { "column": "limit_time", "kind": "node", "field": "limit_time", "default": 1 },
    { "column": "listener_data", "kind": "const", "default": "" },
    { "column": "action_trigger", "kind": "node", "field": "action_trigger", "default": "" },
    { "column": "action_trigger_active", "kind": "node", "field": "action_trigger_active", "default": "" },
    { "column": "shop_action", "kind": "node", "field": "shop_action", "default": 0 },
    { "column": "relation_parameter", "kind": "const", "default": "" }
  ],
  "validation_rules": [
    { "name": "duplicate_parameter", "fields": ["parameter"] },
    { "name": "touchidle_draw_conflict", "fields": ["draw_able_name", "action_trigger", "action_trigger_active"] },
    { "name": "parts_data_format", "fields": ["parts_data"] },
    { "name": "parts_data_range", "fields": ["parts_data", "range"] },
    { "name": "duplicate_initial", "fields": [] }
  ],
  "nodes": {
    "Initial": {
      "title": "初始节点",
      "category": "meta",
      "copyable": false,
      "quick_create": false,
      "resizable": false,
      "header_color": "#4f7c6a",
      "body_color": "#2b4139",
      "accent_color": "#6fc49e",
      "fields": [
        { "key": "tips", "label": "备注", "editor": "text", "default": "", "show_in_modes": ["simple", "advanced"] },
        { "key": "version", "label": "版本", "editor": "date", "default": "2099-09-09", "show_in_modes": ["simple", "advanced"] },
        { "key": "defaultState", "label": "默认状态", "editor": "text", "default": "idle0", "show_in_modes": ["simple", "advanced"] },
        { "key": "CharName", "label": "角色名", "editor": "text", "default": "", "show_in_modes": ["simple", "advanced"] },
        { "key": "memo", "label": "角色资源名", "editor": "text", "default": "", "show_in_modes": ["simple", "advanced"] },
        { "key": "ship_skin_id", "label": "角色ID", "editor": "int", "default": 0, "show_in_modes": ["simple", "advanced"] },
        { "key": "react_condition", "label": "允许目光拖拽的待机", "editor": "int", "default": 0, "show_in_modes": ["simple", "advanced"] },
        { "key": "author", "label": "作者", "editor": "text", "default": "", "show_in_modes": ["simple", "advanced"] }
      ]
    },
    "TouchIdle": {
      "title": "TouchIdle",
      "category": "function",
      "copyable": true,
      "quick_create": true,
      "resizable": false,
      "header_color": "#4a7ec7",
      "body_color": "#27384d",
      "accent_color": "#78b1ff",
      "auto_rules": {
        "draw_template": "TouchIdle{sequence}",
        "parameter_template": "Paramtouch_idle{target_idle}",
        "action_name_template": "touch_idle{target_idle}",
        "use_sequence_for_target_idle": true,
        "supports_quick_create": true
      },
      "fields": [
        { "key": "tips", "label": "备注", "editor": "text", "default": "", "show_in_modes": ["simple"] },
        { "key": "draw_able_name", "label": "框", "editor": "text", "default": "", "show_in_modes": ["simple", "advanced"] },
        { "key": "parameter", "label": "参数", "editor": "text", "default": "", "show_in_modes": ["simple", "advanced"] },
        { "key": "range", "label": "参数范围", "editor": "range", "default": "{0,1}", "show_in_modes": ["simple", "advanced"] },
        {
          "key": "control_type",
          "label": "交互类型",
          "editor": "combo",
          "default": "click",
          "show_in_modes": ["simple"],
          "options": [
            { "label": "点击", "value": "click" },
            { "label": "拖拽", "value": "drag" }
          ]
        },
        {
          "key": "drag_ui_direction",
          "label": "拖拽方向",
          "editor": "combo",
          "default": "",
          "show_in_modes": ["simple"],
          "visibility": { "field": "control_type", "equals": "drag" },
          "options": [
            { "label": "无", "value": "" },
            { "label": "上", "value": "up" },
            { "label": "下", "value": "down" },
            { "label": "左", "value": "left" },
            { "label": "右", "value": "right" }
          ]
        },
        {
          "key": "transition_type",
          "label": "过渡形式",
          "editor": "combo",
          "default": "animated",
          "show_in_modes": ["simple"],
          "options": [
            { "label": "动画", "value": "animated" },
            { "label": "硬切", "value": "hard" }
          ]
        },
        {
          "key": "action_trigger",
          "label": "播放的动画",
          "editor": "text",
          "default": "",
          "show_in_modes": ["simple", "advanced"],
          "visibility": { "field": "transition_type", "not_equals": "hard" }
        },
        { "key": "action_trigger_active", "label": "目标idle", "editor": "int", "default": 1, "show_in_modes": ["simple", "advanced"] },
        { "key": "id", "label": "ID", "editor": "int", "default": 0, "show_in_modes": ["advanced"], "read_only": true },
        {
          "key": "mode",
          "label": "数值模式",
          "editor": "combo",
          "default": 1,
          "show_in_modes": ["advanced"],
          "options": [
            { "label": "覆盖", "value": 1 },
            { "label": "加法", "value": 2 },
            { "label": "乘法", "value": 3 }
          ]
        },
        { "key": "start_value", "label": "初始值", "editor": "int", "default": 0, "show_in_modes": ["advanced"] },
        { "key": "parts_data", "label": "数值吸附范围", "editor": "text", "default": "", "show_in_modes": ["advanced"] },
        { "key": "ignore_react", "label": "屏蔽目光跟随", "editor": "bool", "default": 1, "show_in_modes": ["advanced"] },
        { "key": "ignore_action", "label": "非待机状态不可拖动", "editor": "bool", "default": 1, "show_in_modes": ["advanced"] },
        { "key": "range_abs", "label": "使用绝对值", "editor": "bool", "default": 1, "show_in_modes": ["advanced"] },
        {
          "key": "drag_direct",
          "label": "方向响应",
          "editor": "combo",
          "default": 0,
          "show_in_modes": ["advanced"],
          "options": [
            { "label": "0 不适用", "value": 0 },
            { "label": "1 正向", "value": 1 },
            { "label": "2 负向", "value": 2 }
          ]
        },
        { "key": "react_pos_x", "label": "眼神跟随X", "editor": "nullable_int", "default": null, "show_in_modes": ["advanced"] },
        { "key": "react_pos_y", "label": "眼神跟随Y", "editor": "nullable_int", "default": null, "show_in_modes": ["advanced"] },
        { "key": "offset_x", "label": "左右移动影响拖拽", "editor": "int", "default": 0, "show_in_modes": ["advanced"] },
        { "key": "offset_y", "label": "上下移动影响拖拽", "editor": "int", "default": 0, "show_in_modes": ["advanced"] },
        { "key": "smooth", "label": "开始拖拽响应系数", "editor": "int", "default": 100, "show_in_modes": ["advanced"] },
        { "key": "revert_smooth", "label": "回弹拖拽响应系数", "editor": "int", "default": 100, "show_in_modes": ["advanced"] },
        { "key": "revert", "label": "回弹延迟", "editor": "int", "default": -1, "show_in_modes": ["advanced"] },
        { "key": "gyro", "label": "陀螺仪启用", "editor": "bool", "default": 0, "show_in_modes": ["advanced"] },
        { "key": "gyro_x", "label": "陀螺仪X轴", "editor": "int", "default": 0, "show_in_modes": ["advanced"] },
        { "key": "gyro_y", "label": "陀螺仪Y轴", "editor": "int", "default": 0, "show_in_modes": ["advanced"] },
        { "key": "gyro_z", "label": "陀螺仪Z轴", "editor": "int", "default": 0, "show_in_modes": ["advanced"] },
        { "key": "limit_time", "label": "触发间隔", "editor": "int", "default": 1, "show_in_modes": ["advanced"] },
        { "key": "shop_action", "label": "商店动作", "editor": "bool", "default": 0, "show_in_modes": ["advanced"] }
      ]
    },
    "TouchDrag": {
      "title": "TouchDrag",
      "category": "function",
      "copyable": true,
      "quick_create": true,
      "resizable": false,
      "header_color": "#7d63c7",
      "body_color": "#332b4f",
      "accent_color": "#b5a1ff",
      "auto_rules": {
        "draw_template": "TouchDrag{sequence}",
        "parameter_template": "Touch_drag{target_idle}",
        "action_name_template": "touch_idle{target_idle}",
        "use_sequence_for_target_idle": true,
        "supports_quick_create": true
      },
      "fields": [
        { "key": "tips", "label": "备注", "editor": "text", "default": "", "show_in_modes": ["simple"] },
        { "key": "draw_able_name", "label": "框", "editor": "text", "default": "", "show_in_modes": ["simple", "advanced"] },
        { "key": "parameter", "label": "参数", "editor": "text", "default": "", "show_in_modes": ["simple", "advanced"] },
        { "key": "range", "label": "参数范围", "editor": "range", "default": "{0,1}", "show_in_modes": ["simple", "advanced"] },
        {
          "key": "control_type",
          "label": "交互类型",
          "editor": "combo",
          "default": "click",
          "show_in_modes": ["simple"],
          "options": [
            { "label": "点击", "value": "click" },
            { "label": "拖拽", "value": "drag" }
          ]
        },
        {
          "key": "drag_ui_direction",
          "label": "拖拽方向",
          "editor": "combo",
          "default": "",
          "show_in_modes": ["simple"],
          "visibility": { "field": "control_type", "equals": "drag" },
          "options": [
            { "label": "无", "value": "" },
            { "label": "上", "value": "up" },
            { "label": "下", "value": "down" },
            { "label": "左", "value": "left" },
            { "label": "右", "value": "right" }
          ]
        },
        {
          "key": "result_type",
          "label": "交互结果",
          "editor": "combo",
          "default": "action",
          "show_in_modes": ["simple"],
          "options": [
            { "label": "播放动画", "value": "action" },
            { "label": "数值变化", "value": "value" }
          ]
        },
        {
          "key": "action_trigger",
          "label": "播放的动画",
          "editor": "text",
          "default": "",
          "show_in_modes": ["simple", "advanced"],
          "visibility": { "field": "result_type", "equals": "action" }
        },
        {
          "key": "action_trigger_active",
          "label": "目标idle",
          "editor": "int",
          "default": 1,
          "show_in_modes": ["simple", "advanced"],
          "visibility": { "field": "result_type", "equals": "action" }
        },
        {
          "key": "target_value",
          "label": "数值变化到",
          "editor": "float",
          "default": 1.0,
          "show_in_modes": ["simple"],
          "visibility": { "field": "result_type", "equals": "value" }
        },
        {
          "key": "revert_enabled",
          "label": "数值是否回弹",
          "editor": "bool",
          "default": 0,
          "show_in_modes": ["simple"],
          "visibility": { "field": "result_type", "equals": "value" }
        },
        { "key": "parts_data", "label": "数值吸附", "editor": "text", "default": "", "show_in_modes": ["simple", "advanced"] },
        { "key": "id", "label": "ID", "editor": "int", "default": 0, "show_in_modes": ["advanced"], "read_only": true },
        {
          "key": "mode",
          "label": "数值模式",
          "editor": "combo",
          "default": 1,
          "show_in_modes": ["advanced"],
          "options": [
            { "label": "覆盖", "value": 1 },
            { "label": "加法", "value": 2 },
            { "label": "乘法", "value": 3 }
          ]
        },
        { "key": "start_value", "label": "初始值", "editor": "int", "default": 0, "show_in_modes": ["advanced"] },
        { "key": "ignore_react", "label": "屏蔽目光跟随", "editor": "bool", "default": 1, "show_in_modes": ["advanced"] },
        { "key": "ignore_action", "label": "非待机状态不可拖动", "editor": "bool", "default": 1, "show_in_modes": ["advanced"] },
        { "key": "range_abs", "label": "使用绝对值", "editor": "bool", "default": 1, "show_in_modes": ["advanced"] },
        {
          "key": "drag_direct",
          "label": "方向响应",
          "editor": "combo",
          "default": 0,
          "show_in_modes": ["advanced"],
          "options": [
            { "label": "0 不适用", "value": 0 },
            { "label": "1 正向", "value": 1 },
            { "label": "2 负向", "value": 2 }
          ]
        },
        { "key": "react_pos_x", "label": "眼神跟随X", "editor": "nullable_int", "default": null, "show_in_modes": ["advanced"] },
        { "key": "react_pos_y", "label": "眼神跟随Y", "editor": "nullable_int", "default": null, "show_in_modes": ["advanced"] },
        { "key": "offset_x", "label": "左右移动影响拖拽", "editor": "int", "default": 0, "show_in_modes": ["advanced"] },
        { "key": "offset_y", "label": "上下移动影响拖拽", "editor": "int", "default": 0, "show_in_modes": ["advanced"] },
        { "key": "smooth", "label": "开始拖拽响应系数", "editor": "int", "default": 100, "show_in_modes": ["advanced"] },
        { "key": "revert_smooth", "label": "回弹拖拽响应系数", "editor": "int", "default": 100, "show_in_modes": ["advanced"] },
        { "key": "revert", "label": "回弹延迟", "editor": "int", "default": -1, "show_in_modes": ["advanced"] },
        { "key": "gyro", "label": "陀螺仪启用", "editor": "bool", "default": 0, "show_in_modes": ["advanced"] },
        { "key": "gyro_x", "label": "陀螺仪X轴", "editor": "int", "default": 0, "show_in_modes": ["advanced"] },
        { "key": "gyro_y", "label": "陀螺仪Y轴", "editor": "int", "default": 0, "show_in_modes": ["advanced"] },
        { "key": "gyro_z", "label": "陀螺仪Z轴", "editor": "int", "default": 0, "show_in_modes": ["advanced"] },
        { "key": "limit_time", "label": "触发间隔", "editor": "int", "default": 1, "show_in_modes": ["advanced"] },
        { "key": "shop_action", "label": "商店动作", "editor": "bool", "default": 0, "show_in_modes": ["advanced"] }
      ]
    },
    "Comment": {
      "title": "备注节点",
      "category": "comment",
      "copyable": true,
      "quick_create": true,
      "resizable": true,
      "header_color": "#9b7c35",
      "body_color": "#5a4a26",
      "accent_color": "#d9b766",
      "fields": [
        { "key": "content", "label": "内容", "editor": "text", "default": "", "show_in_modes": ["simple", "advanced"], "multiline": true }
      ]
    }
  }
}
