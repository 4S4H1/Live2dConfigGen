        {
          "key": "author",
          "label": "作者",
          "editor": "text",
          "default": "",
          "placeholder": "君の名は。",
          "show_in_modes": [
            "simple",
            "advanced"
          ]
        }
      ]
    },
    "TouchIdle": {
      "title": "TouchIdle",
      "category": "function",
      "copyable": true,
      "quick_create": true,
      "resizable": false,
      "header_color": "#4a7ec7",
      "body_color": "#27384d",
      "accent_color": "#78b1ff",
      "auto_rules": {
        "draw_template": "TouchIdle{sequence}",
        "parameter_template": "Paramtouch_idle{target_idle}",
        "action_name_template": "touch_idle{target_idle}",
        "use_sequence_for_target_idle": true,
        "supports_quick_create": true
      },
      "fields": [
        {
          "key": "tips",
          "label": "备注",
          "editor": "text",
          "default": "",
          "placeholder": "这个交互是做什么的",
          "show_in_modes": [
            "simple"
          ]
        },
        {
          "key": "desc",
          "label": "说明",
          "editor": "text",
          "default": "",
          "show_in_modes": [
            "advanced"
          ]
        },
        {
          "key": "draw_able_name",
          "label": "框",
          "editor": "text",
          "default": "",
          "placeholder": "如 TouchIdle12，注意大小写",
          "show_in_modes": [
            "simple",
            "advanced"
          ]
        },
        {
          "key": "parameter",
          "label": "参数",
          "editor": "text",
          "default": "",
          "placeholder": "如 Paramtouch_idle12，注意大小写",
          "show_in_modes": [
            "simple",
            "advanced"
          ]
        },
        {
          "key": "range",
          "label": "参数范围",
          "editor": "range",
          "default": "{0,1}",
          "show_in_modes": [
            "simple",
            "advanced"
          ]
        },
        {
          "key": "control_type",
          "label": "交互类型",
          "editor": "combo",
          "default": "click",
          "show_in_modes": [
            "simple"
          ],
          "options": [
            {
              "label": "点击",
              "value": "click"
            },
            {
              "label": "拖拽",
              "value": "drag"
            }
          ]
        },
        {
          "key": "drag_ui_direction",
          "label": "拖拽方向",
          "editor": "combo",
          "default": "",
          "show_in_modes": [
            "simple"
          ],
          "visibility": {
            "field": "control_type",
            "equals": "drag"
          },
          "options": [
            {
              "label": "无",
              "value": ""
            },
            {
              "label": "上",
              "value": "up"
            },
            {
              "label": "下",
              "value": "down"
            },
            {
              "label": "左",
              "value": "left"
            },
            {
              "label": "右",
              "value": "right"
            }
          ]
        },
        {
          "key": "transition_type",
          "label": "过渡形式",
          "editor": "combo",
          "default": "animated",
          "show_in_modes": [
            "simple"
          ],
          "options": [
            {
              "label": "动画",
              "value": "animated"
            },
            {
              "label": "硬切",
              "value": "hard"
            }
          ]
        },
        {
          "key": "action_trigger",
          "label": "播放的动画",
          "editor": "text",
          "placeholder": "如 touch_idle1，注意大小写",
          "default": "",
          "show_in_modes": [
            "simple",
            "advanced"
          ],
          "visibility": {
            "field": "transition_type",
            "not_equals": "hard"
          }
        },
        {
          "key": "action_trigger_active",
          "label": "目标idle",
          "editor": "int",
          "default": 1,
          "placeholder": "要跳到哪个idle，如 1",
          "show_in_modes": [
            "simple",
            "advanced"
          ]
        },
        {
          "key": "action_trigger_kind_ui",
          "label": "触发器类型",
          "editor": "combo",
          "default": "type2_action",
          "show_in_modes": [
            "advanced"
          ],
          "read_only": true,
          "options": [
            {
              "label": "当前为空",
              "value": "empty"
            },
            {
              "label": "type=2 动作触发",
              "value": "type2_action"
            },
            {
              "label": "type=2 目标触发",
              "value": "type2_target"
            },
            {
              "label": "预留其他类型",
              "value": "reserved_raw"
            }
          ]
        },
        {
          "key": "action_trigger_reserved_ui",
          "label": "预留触发配置",
          "editor": "text",
          "default": "",
          "read_only": true,
          "show_in_modes": [
            "advanced"
          ],
          "visibility": {
            "field": "action_trigger_kind_ui",
            "equals": "reserved_raw"
          }
        },
        {
          "key": "action_trigger_active_kind_ui",
          "label": "状态门控类型",
          "editor": "combo",
          "default": "idle_gate",
          "show_in_modes": [
            "advanced"
          ],
          "read_only": true,
          "options": [
            {
              "label": "当前为空",
              "value": "empty"
            },
            {
              "label": "idle 门控",
              "value": "idle_gate"
            },
            {
              "label": "预留其他类型",
              "value": "reserved_raw"
            }
          ]
        },
        {
          "key": "action_trigger_active_reserved_ui",
          "label": "预留门控配置",
          "editor": "text",
          "default": "",
          "read_only": true,
          "show_in_modes": [
            "advanced"
          ],
          "visibility": {
            "field": "action_trigger_active_kind_ui",
            "equals": "reserved_raw"
          }
        },
        {
          "key": "id",
          "label": "ID",
          "editor": "int",
          "default": 0,
          "show_in_modes": [
            "advanced"
          ],
          "read_only": true
        },
        {
          "key": "mode",
          "label": "数值模式",
          "editor": "combo",
          "default": 1,
          "show_in_modes": [
            "advanced"
          ],
          "options": [
            {
              "label": "覆盖",
              "value": 1
            },
            {
              "label": "加法",
              "value": 2
            },
            {
              "label": "乘法",
              "value": 3
            }
          ]
        },
        {
          "key": "start_value",
          "label": "初始值",
          "editor": "int",
          "default": 0,
          "show_in_modes": [
            "advanced"
          ]
        },
        {
          "key": "parts_data",
          "label": "数值吸附范围",
          "editor": "text",
          "default": "",
          "placeholder": "非必填，要填的话填0,1,2这样的",
          "show_in_modes": [
            "advanced"
          ]
        },
        {
          "key": "ignore_react",
